#!/usr/bin/env bash
# Enforces Conventional Commits on the first line (see CONTRIBUTING.md).
set -euo pipefail

msg_file="${1:?commit-msg hook requires message file path}"
commit_msg="$(head -n 1 "$msg_file")"

# Merge commits from Git
if echo "$commit_msg" | grep -qE '^Merge '; then
  exit 0
fi

# Types aligned with CONTRIBUTING + common extensions (build, revert)
# Subject must be non-empty after ": "
pattern='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([^)]+\))?: .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Commit message does not follow Conventional Commits."
  echo ""
  echo "   Format: <type>(<optional-scope>): <subject>"
  echo ""
  echo "   Types: feat fix docs style refactor test chore perf ci build revert"
  echo ""
  echo "   Examples:"
  echo "     feat(auth): add biometric login"
  echo "     fix: handle null user after logout"
  echo "     docs(readme): update install steps"
  echo ""
  echo "   Bypass (rare): git commit --no-verify"
  exit 1
fi
