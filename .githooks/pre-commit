#!/usr/bin/env bash
# Runs before each commit. Keeps scope aligned with CI (see .github/workflows/ci.yml).
set -euo pipefail

echo "Running pre-commit checks..."

if ! command -v flutter >/dev/null 2>&1; then
  echo "⚠️  Flutter not found. Skipping pre-commit checks."
  exit 0
fi

echo "📝 Checking code formatting..."
if ! dart format --set-exit-if-changed lib test integration_test tool examples; then
  echo "❌ Code formatting check failed."
  echo "   Fix: ./scripts/dev/format_dart.sh"
  echo "   Or: dart format lib test integration_test tool examples"
  exit 1
fi

echo "🔍 Running flutter analyze..."
if ! flutter analyze; then
  echo "❌ flutter analyze failed."
  exit 1
fi

echo "✅ Pre-commit checks passed."
